<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.MainActivity">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Ảnh chọn từ gallery -->
    <ImageView
        android:id="@+id/ivSelectedImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:visibility="gone"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="@+id/scanOverlay"
        app:layout_constraintBottom_toBottomOf="@+id/scanOverlay"
        app:layout_constraintStart_toStartOf="@+id/scanOverlay"
        app:layout_constraintEnd_toEndOf="@+id/scanOverlay" />

    <!-- Khung quét -->
    <View
        android:id="@+id/scanOverlay"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:background="@drawable/scanner_shutter_border"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.4" />

    <!-- Hướng dẫn -->
    <TextView
        android:id="@+id/tvInstruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đưa lá cây vào trung tâm khung quét"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:shadowColor="#000000"
        android:shadowRadius="6"
        android:background="@drawable/bg_instruction_rounded"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toTopOf="@+id/scanOverlay"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <!-- CardView kết quả (Đã căn chỉnh trục đối xứng và phân bổ khoảng cách hoàn hảo) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#CCFFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Đã sửa: Đồng bộ trục thẳng hàng tuyệt đối giữa Tiêu đề và Nút Nhật ký -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="KẾT QUẢ CHẨN ĐOÁN:"
                    android:textColor="#666666"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:gravity="center_vertical"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenHistory"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 Nhật ký"
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:onClick="openHistoryActivityFromXml" />
            </LinearLayout>

            <!-- Khối văn bản kết quả giữ nguyên khoảng đệm mượt mà -->
            <LinearLayout
                android:id="@+id/layoutResultClick"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:minHeight="52dp"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <TextView
                    android:id="@+id/resultTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đang nạp dữ liệu..."
                    android:textColor="#2E7D32"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvClickGuide"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="👉 Nhấn vào đây để xem giải pháp chi tiết"
                    android:textColor="#1565C0"
                    android:textSize="12.5sp"
                    android:textStyle="italic|bold"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Đã sửa: Cân bằng tỷ lệ nút bấm, ép icon và chữ đồng tâm đối xứng tuyệt đối -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:weightSum="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickImage"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#616161"
                    android:text="Chọn ảnh"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_gallery"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAction"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="#2E7D32"
                    android:text="Tạm dừng"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_pause"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>