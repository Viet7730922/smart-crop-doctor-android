<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <!-- Khối bố cục hàng ngang chứa ảnh thu nhỏ, thông tin kết quả và nút xóa -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Ảnh thu nhỏ -->
        <androidx.cardview.widget.CardView
            android:layout_width="70dp"
            android:layout_height="70dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">
            <ImageView
                android:id="@+id/ivHistoryItem"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#E0E0E0" />
        </androidx.cardview.widget.CardView>

        <!-- Thông tin bệnh và thời gian -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tvHistoryName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên bệnh cây"
                android:textColor="#2E7D32"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHistoryTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="24/05/2026 15:30"
                android:textColor="#888888"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Nút xóa (đã loại bỏ khung) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteHistory"
            style="?attr/borderlessButtonStyle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="10dp"
            app:icon="@android:drawable/ic_menu_delete"
            app:iconSize="22dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="#C62828"
            app:rippleColor="#15C62828" />

    </LinearLayout>
</androidx.cardview.widget.CardView>